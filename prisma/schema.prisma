// prisma/schema.prisma
datasource db {
  provider  = "postgresql"
  url  	    = env("DATABASE_URL")
  // uncomment next line if you use Prisma <5.10
  // directUrl = env("DATABASE_URL_UNPOOLED")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  USER
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  // カレンダーの「色＝人」で使う本人選択のテーマカラー（#RRGGBB）。
  // null は未選択＝従来どおり名前ハッシュで自動割り当て（lib/calendar/member-colors.ts）。
  color         String?
  password      String?
  role          UserRole  @default(USER)
  // 最後に選択していたワークスペース（セッションの currentWorkspaceId の永続先）。
  // 有効な membership が無い値になっていても jwt-refresh 側でフォールバックする。
  lastWorkspaceId String? @map("last_workspace_id")
  accounts      Account[]
  isTwoFactorEnabled Boolean @default(false)
  twoFactorConfirmation TwoFactorConfirmation?
  settings      UserSettings?
  feedbacks     Feedback[]

  @@map("users")
}

// 部員からのアプリ内フィードバック（ユーザーメニューの1タップ送信）。
// 閲覧は開発者専用ページ /dev/feedback（部長向け管理画面とは別系統）。
model Feedback {
  id        Int      @id @default(autoincrement())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  body      String
  path      String?  // 送信元ページ（自動付与）
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([resolved, createdAt])
  @@map("feedback")
}

enum CalendarView {
  MONTH
  GANTT
}

model UserSettings {
  id                      String       @id @default(cuid())
  userId                  String       @unique @map("user_id")
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifyReturnReminder    Boolean      @default(true)  @map("notify_return_reminder")
  notifyReservationEvents Boolean      @default(true)  @map("notify_reservation_events")
  notifyNewEquipment      Boolean      @default(false) @map("notify_new_equipment")
  lineNotifyEnabled       Boolean      @default(false) @map("line_notify_enabled")
  lineUserId              String?      @unique @map("line_user_id")
  calendarDefaultView     CalendarView @default(MONTH) @map("calendar_default_view")

  @@map("user_settings")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model VerificationToken {
  id String @id @default(cuid())
  email String
  token String @unique
  expires DateTime


  @@unique([email, token])
}

model PasswordResetToken {
  id String @id @default(cuid())
  email String
  token String @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id String @id @default(cuid())
  email String
  token String @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorConfirmation {
  id String @id @default(cuid())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

// ワークスペース（=利用団体）。マルチテナント化の境界。既存の放送部は
// migration で固定 id "ws_abs_default"（slug "abs"）の行として作成される。
model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  @@map("workspaces")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

// ユーザーとワークスペースの所属関係（1人が複数団体に所属できる）。
// 機材・タグ・他人予約の管理権限は将来ここ（OWNER/ADMIN）へ一本化し、
// グローバル UserRole.ADMIN は開発者/運用向けに縮退させる。
// List/Reserve と同じ生FKスタイル（リレーション宣言なし）。
model Membership {
  id          String        @id @default(cuid())
  userId      String        @map("user_id")
  workspaceId String        @map("workspace_id")
  role        WorkspaceRole @default(MEMBER)
  createdAt   DateTime      @default(now()) @map("created_at")

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("memberships")
}

// ワークスペースへの招待コード（P3 で使用。テーブルだけ先行して用意）。
model WorkspaceInvite {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  code        String        @unique
  role        WorkspaceRole @default(MEMBER)
  expiresAt   DateTime?     @map("expires_at")
  maxUses     Int?          @map("max_uses")
  usedCount   Int           @default(0) @map("used_count")
  createdBy   String?       @map("created_by")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@map("workspace_invites")
}

model List {
  id      Int  @id @default(autoincrement())
  name    String?
  detail  String?
  image   String?
  usable  Boolean @default(true)
  tag_id  Int?
  // テナント境界。DB デフォルトで既定ワークスペースに落ちるため、workspace_id を
  // 知らない旧コードの INSERT も壊れない（デフォルトは権限移行完了後に撤去予定）。
  workspaceId String @default("ws_abs_default") @map("workspace_id")
}

model Reserve {
  id        Int  @id @default(autoincrement())
  user_id   String?
  start     DateTime?
  end       DateTime?
  list_id   Int?
  isRenting Int? @default(0)
  // 返却リマインダー（cron）の二重送信防止。最後に通知した「返却期限日」を
  // JST 日付の UTC 00:00 で記録する。cron が同日に複数回発火してもこの列で弾く。
  remindedOn DateTime? @map("reminded_on")
  // 実際に返却した日（JST 日付の UTC 00:00）。end は「予約していた返却期限」として
  // 保持し続け、早期返却しても書き換えない（履歴保全・マイページのグループ化維持）。
  // 空き解放は重複チェック側の isRenting=4 除外で行う。
  returnedAt DateTime? @map("returned_at")
  // テナント境界（List と同じ方針）
  workspaceId String @default("ws_abs_default") @map("workspace_id")

  // POST の重複(期間重なり)チェック route.ts の findFirst({ list_id, start<=E, end>=S }) と
  // ?list_id= フィルタに効く。等値 list_id を先頭、範囲 start を第2列に。
  @@index([list_id, start])
  // ?user_id= フィルタ(本人予約一覧)に効く。
  @@index([user_id, start])
}

model Tag {
  id        Int  @id @default(autoincrement())
  name      String?
  color     String @default("#3788D8")
  sortOrder Int    @default(0) @map("sort_order")
  // テナント境界（List と同じ方針）
  workspaceId String @default("ws_abs_default") @map("workspace_id")
}
